// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MovementType {
  TRANSFER
  PROMOTION
  TRANSFER_PROMOTION
}

enum ExperienceType {
  FRESHER
  EXPERIENCED
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  remark    String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  roleModules RoleModule[]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  password  String
  firstName String
  lastName  String
  email     String   @unique
  status    Status   @default(ACTIVE)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id])

  employeeProfile     EmployeeProfile?
}

model JobRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  employeeProfiles EmployeeProfile[]
}

model Department {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  employeeProfiles EmployeeProfile[]
}

model WorkLocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  code        String   @unique
  address     String
  city        String
  state       String
  country     String
  postalCode  String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transfersFrom TransferPromotion[] @relation("TransferFromLocation")
  transfersTo   TransferPromotion[] @relation("TransferToLocation")
  employeeProfiles EmployeeProfile[]
}

model TransferPromotion {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId         String       @db.Uuid
  movementType       MovementType
  fromLocationId     String?      @db.Uuid
  toLocationId       String?      @db.Uuid
  currentDesignation String?
  newDesignation     String?
  effectiveDate      DateTime
  reason             String
  remark             String?
  status             Status       @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  employee     EmployeeProfile @relation(fields: [employeeId], references: [id])
  fromLocation WorkLocation? @relation("TransferFromLocation", fields: [fromLocationId], references: [id])
  toLocation   WorkLocation? @relation("TransferToLocation", fields: [toLocationId], references: [id])
}

model EmployeeDocument {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId         String         @db.Uuid
  employeeCode       String

  // ---------------- DOCUMENTS ----------------
  aadhaarNumber      String
  aadhaarFileUrl     String?
  panNumber          String
  panFileUrl         String?

  // ---------------- EDUCATION (DYNAMIC CARDS) ----------------
  educationEntries   Json?

  // ---------------- EXPERIENCE ----------------
  experienceType     ExperienceType @default(FRESHER)
  experienceEntries  Json?

  // ---------------- COMMON ----------------
  remark             String?
  status             Status         @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  employee EmployeeProfile @relation(fields: [employeeId], references: [id])
}

model EmployeeProfile {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId            String?  @unique @db.Uuid
  employeeName          String
  employeeCode          String   @unique
  phone                 String
  alternatePhone        String?
  gender                String?
  dateOfBirth           DateTime?
  joiningDate           DateTime
  departmentId          String?  @db.Uuid
  jobRoleId             String?  @db.Uuid
  workLocationId        String?  @db.Uuid
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  remark                String?
  status                Status   @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employee     User?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  department   Department?   @relation(fields: [departmentId], references: [id])
  jobRole      JobRole?      @relation(fields: [jobRoleId], references: [id])
  workLocation WorkLocation? @relation(fields: [workLocationId], references: [id])
  employeeDocuments EmployeeDocument[]
  transferPromotions TransferPromotion[]
}

model Module {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "module_name_idx")
  description String
  route       String @unique
  status      Status @default(ACTIVE)

  roleModules RoleModule[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model RoleModule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId   String @db.Uuid
  moduleId String @db.Uuid

  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}
