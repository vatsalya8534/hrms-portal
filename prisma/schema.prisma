generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum MovementType {
  TRANSFER
  PROMOTION
  TRANSFER_PROMOTION
}

enum ExperienceType {
  FRESHER
  EXPERIENCED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  remark    String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  roleModules RoleModule[]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  password  String
  firstName String
  lastName  String
  email     String   @unique
  status    Status   @default(ACTIVE)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleId    String   @db.Uuid
  role      Role     @relation(fields: [roleId], references: [id])

  employeeProfile EmployeeProfile?
  projects        Project[]
}

model Company {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName String   @unique
  companyCode String   @unique
  email       String?  @unique
  phone       String
  website     String?
  address     String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employers        Employer[]
  employeeProfiles EmployeeProfile[]
}

model Employer {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @db.Uuid
  employerName String
  employerCode String   @unique
  email        String   @unique
  phone        String
  password     String
  designation  String?
  address      String?
  remark       String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  employeeProfiles EmployeeProfile[]
}

model Department {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  code        String   @unique
  description String?
  remark      String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  employeeProfiles EmployeeProfile[]
}

model WorkLocation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique
  code       String   @unique
  address    String
  city       String
  state      String
  country    String
  postalCode String?
  remark     String?
  status     Status   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transfersFrom    TransferPromotion[] @relation("TransferFromLocation")
  transfersTo      TransferPromotion[] @relation("TransferToLocation")
  employeeProfiles EmployeeProfile[]
}

model TransferPromotion {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId         String       @db.Uuid
  movementType       MovementType
  fromLocationId     String?      @db.Uuid
  toLocationId       String?      @db.Uuid
  currentDesignation String?
  newDesignation     String?
  effectiveDate      DateTime
  reason             String
  remark             String?
  status             Status       @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  employee     EmployeeProfile @relation(fields: [employeeId], references: [id])
  fromLocation WorkLocation?   @relation("TransferFromLocation", fields: [fromLocationId], references: [id])
  toLocation   WorkLocation?   @relation("TransferToLocation", fields: [toLocationId], references: [id])
}

model EmployeeDocument {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String @db.Uuid
  employeeCode String

  // ---------------- DOCUMENTS ----------------
  aadhaarNumber  String
  aadhaarFileUrl String?
  panNumber      String
  panFileUrl     String?

  // ---------------- EDUCATION (DYNAMIC CARDS) ----------------
  educationEntries Json?

  // ---------------- EXPERIENCE ----------------
  experienceType    ExperienceType @default(FRESHER)
  experienceEntries Json?

  // ---------------- COMMON ----------------
  remark    String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee EmployeeProfile @relation(fields: [employeeId], references: [id])
}

model EmployeeProfile {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String? @unique @db.Uuid
  employeeName String
  employeeCode String  @unique

  companyId String? @db.Uuid

  phone          String
  alternatePhone String?
  gender         String?
  dateOfBirth    DateTime?
  joiningDate    DateTime

  departmentId   String? @db.Uuid
  jobRoleId      String? @db.Uuid
  workLocationId String? @db.Uuid

  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  remark                String?
  status                Status   @default(ACTIVE)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employee     User?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  jobRole      JobRole?      @relation(fields: [jobRoleId], references: [id])
  workLocation WorkLocation? @relation(fields: [workLocationId], references: [id])

  employeeDocuments  EmployeeDocument[]
  transferPromotions TransferPromotion[]
  projectMembers     ProjectMember[]
  tasks              Task[]
  taskComments       TaskComment[]
}

model Module {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "module_name_idx")
  description String
  route       String @unique
  status      Status @default(ACTIVE)

  roleModules RoleModule[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model RoleModule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId   String @db.Uuid
  moduleId String @db.Uuid

  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}

model Configuration {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String?
  logo     String?
  favicon  String?
  email    String?
  password String?
}

model Project {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?

  startDate DateTime
  endDate   DateTime?

  status ProjectStatus @default(PLANNING)

  createdById String @db.Uuid

  createdBy User @relation(fields: [createdById], references: [id])

  members ProjectMember[]
  tasks   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMember {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String @db.Uuid
  employeeId String @db.Uuid

  assignedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project         @relation(fields: [projectId], references: [id])
  employee EmployeeProfile @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
}

model Task {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String  @db.Uuid
  assignedToId String? @db.Uuid

  title       String
  description String?

  status   TaskStatus @default(TODO)
  priority Priority   @default(MEDIUM)

  startDate DateTime?
  dueDate   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignedTo EmployeeProfile? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  comments TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assignedToId])
}

model TaskComment {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId     String @db.Uuid
  employeeId String @db.Uuid

  comment String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  employee EmployeeProfile @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([employeeId])
}
